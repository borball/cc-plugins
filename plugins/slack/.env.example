# Slack API credentials (browser session tokens)
# Extract from browser DevTools or use slack-token-extractor
# See: https://github.com/maorfr/slack-token-extractor

# REQUIRED: Slack client token (from localStorage or Network tab)
SLACK_XOXC_TOKEN=xoxc-your-token-here

# REQUIRED: Slack session cookie (from Application > Cookies > "d")
SLACK_XOXD_TOKEN=xoxd-your-token-here

# OPTIONAL: Workspace name (for display purposes)
SLACK_WORKSPACE=
