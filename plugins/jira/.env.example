# Jira Configuration (compatible with Jira MCP server)
JIRA_URL=https://your-domain.atlassian.net
JIRA_USERNAME=your-email@example.com
JIRA_API_TOKEN=your-api-token-here

# Jira Project (used for filtering tickets)
JIRA_PROJECT_KEY=PROJ

# Optional: default JQL filter for picking tickets
JIRA_JQL_FILTER="assignee = currentUser() AND status != Done ORDER BY updated DESC"

# Optional: defaults for ticket creation
# JIRA_DEFAULT_PARENT=PROJ-100        # parent ticket for new issues
# JIRA_DEFAULT_TYPE=Task              # issue type (Task, Story, Bug, Sub-task)
